# ─── Frontend Environment Variables ──────────────────────────────────────────
#
# VITE_API_URL — Full URL of your deployed backend on Vercel.
# Leave as /api in local development — Vite's dev proxy handles it.
#
# Example (production):
#   VITE_API_URL=https://your-backend-project.vercel.app/api
#
VITE_API_URL=/api
