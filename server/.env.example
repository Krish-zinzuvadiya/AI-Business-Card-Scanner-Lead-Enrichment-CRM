NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
MONGO_URI=mongodb://127.0.0.1:27017/business_card_crm

# Local upload storage (used only when CLOUDINARY_CLOUD_NAME is not set)
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=8

# ─── Cloudinary (required on Vercel / production) ─────────────────────────────
# Sign up free at https://cloudinary.com · go to Dashboard · copy these values
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: folder name inside your Cloudinary media library
CLOUDINARY_FOLDER=business-card-crm

# ─── Tesseract OCR ────────────────────────────────────────────────────────────
# Set to "true" to fetch eng.traineddata from CDN instead of local file.
# Automatically forced to CDN mode when NODE_ENV=production.
TESSERACT_CDN=false

# ─── Enrichment ───────────────────────────────────────────────────────────────
ENABLE_ENRICHMENT=true
ENRICHMENT_MIN_DELAY_MS=2000
ENRICHMENT_MAX_DELAY_MS=5000
ENRICHMENT_PAGE_LIMIT=5
ENRICHMENT_TIMEOUT_MS=9000

# ─── Optional OpenAI Parsing ─────────────────────────────────────────────────
# Leave USE_OPENAI_PARSER=false to use the free local parser.
USE_OPENAI_PARSER=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Rate limits ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
